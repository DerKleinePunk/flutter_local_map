{
  "version": 8,
  "name": "openmaptiles-offline-navigation",
  "metadata": {
    "generator": "tilemaker-openmaptiles",
    "offline": true,
    "variant": "navigation"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": [
        "mbtiles://{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 16
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f6f4ef"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#dbe9ce",
        "fill-opacity": 0.78
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#ebe4d2",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#c4dfab",
        "fill-opacity": 0.88
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#9fcbf0"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#5ca8df",
        "line-width": 1.4
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#6f7782",
        "line-width": 0.9
      }
    },
    {
      "id": "transportation-casing-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 8,
      "filter": [
        "in",
        "class",
        "motorway",
        "trunk",
        "primary"
      ],
      "paint": {
        "line-color": "#8a5c3c",
        "line-width": 3.6
      }
    },
    {
      "id": "transportation-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 8,
      "filter": [
        "in",
        "class",
        "motorway",
        "trunk",
        "primary"
      ],
      "paint": {
        "line-color": "#f2c47d",
        "line-width": 2.3
      }
    },
    {
      "id": "transportation-casing-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": [
        "in",
        "class",
        "secondary",
        "tertiary"
      ],
      "paint": {
        "line-color": "#8f6f52",
        "line-width": 2.8
      }
    },
    {
      "id": "transportation-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": [
        "in",
        "class",
        "secondary",
        "tertiary"
      ],
      "paint": {
        "line-color": "#f8deac",
        "line-width": 1.9
      }
    },
    {
      "id": "transportation-local",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "in",
        "class",
        "residential",
        "service",
        "unclassified"
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": 1.2
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#ccb8a7",
        "fill-opacity": 0.82
      }
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "line-color": "#b39a85",
        "line-width": 0.5
      }
    },
    {
      "id": "water-name-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 8,
      "layout": {
