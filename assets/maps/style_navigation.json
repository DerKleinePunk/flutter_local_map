        "text-size": 11
      },
      "paint": {
        "text-color": "#5d3a29",
        "text-halo-color": "#f6f4ef",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 6,
      "layout": {
        "text-field": "{name}",
        "text-size": 12
      },
      "paint": {
        "text-color": "#2f3135",
        "text-halo-color": "#f6f4ef",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "layout": {
        "text-field": "{name}",
        "text-size": 10
      },
      "paint": {
