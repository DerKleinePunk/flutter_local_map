{
  "version": 8,
  "name": "openmaptiles-offline-contrast",
  "metadata": {
    "generator": "tilemaker-openmaptiles",
    "offline": true,
    "variant": "alt"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": [
        "mbtiles://{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 16
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#e8ecef"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#d3e4c8",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#ece4cf",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#bddaa7",
        "fill-opacity": 0.85
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#93c3ea"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#4e9dd6",
